<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.KeywordRecordKeyboard" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary</item>
        <item name="colorOnPrimary">@android:color/white</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <style name="KeyboardBaseKeyStyle" parent="Widget.AppCompat.Button.Borderless">
        <item name="android:textAllCaps">false</item>
        <item name="android:padding">0dp</item>
        <item name="android:minHeight">0dp</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:stateListAnimator">@null</item>
        <item name="android:elevation">0dp</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textColor">@color/key_text</item>
        <item name="android:includeFontPadding">false</item>
    </style>

    <style name="KeyboardLetterKeyStyle" parent="KeyboardBaseKeyStyle">
        <item name="android:background">@drawable/key_background_selector</item>
        <item name="android:textSize">@dimen/key_text_size</item>
    </style>

    <style name="KeyboardFunctionKeyStyle" parent="KeyboardBaseKeyStyle">
        <item name="android:background">@drawable/key_function_selector</item>
        <item name="android:textSize">@dimen/key_function_text_size</item>
        <item name="android:textColor">@color/key_text_secondary</item>
    </style>

    <style name="KeyboardSpaceKeyStyle" parent="KeyboardBaseKeyStyle">
        <item name="android:background">@drawable/key_space_selector</item>
    </style>

    <style name="KeyboardIconKeyStyle">
        <item name="android:background">@drawable/key_function_selector</item>
        <item name="android:scaleType">fitCenter</item>
        <item name="android:padding">@dimen/key_icon_padding</item>
        <item name="android:stateListAnimator">@null</item>
        <item name="android:elevation">0dp</item>
        <item name="android:adjustViewBounds">true</item>
    </style>

    <style name="KeyboardEnterIconKeyStyle">
        <item name="android:background">@drawable/key_enter_selector</item>
        <item name="android:scaleType">fitCenter</item>
        <item name="android:padding">@dimen/key_icon_padding</item>
        <item name="android:stateListAnimator">@null</item>
        <item name="android:elevation">0dp</item>
        <item name="android:adjustViewBounds">true</item>
    </style>

    <style name="ToolbarIconButtonStyle">
        <item name="android:layout_width">@dimen/toolbar_icon_touch</item>
        <item name="android:layout_height">@dimen/toolbar_icon_touch</item>
        <item name="android:layout_weight">1</item>
        <item name="android:background">@android:color/transparent</item>
        <item name="android:scaleType">fitCenter</item>
        <item name="android:padding">8dp</item>
        <item name="android:stateListAnimator">@null</item>
    </style>

    <style name="KeyboardSearchKeyStyle">
        <item name="android:background">@drawable/key_enter_circle_selector</item>
        <item name="android:scaleType">fitCenter</item>
        <item name="android:padding">12dp</item>
        <item name="android:stateListAnimator">@null</item>
        <item name="android:elevation">0dp</item>
        <item name="android:adjustViewBounds">true</item>
    </style>

    <style name="KeyboardFooterIconStyle">
        <item name="android:layout_width">@dimen/keyboard_footer_icon_size</item>
        <item name="android:layout_height">@dimen/keyboard_footer_icon_size</item>
        <item name="android:background">@android:color/transparent</item>
        <item name="android:scaleType">fitCenter</item>
        <item name="android:padding">0dp</item>
        <item name="android:stateListAnimator">@null</item>
    </style>
</resources>
